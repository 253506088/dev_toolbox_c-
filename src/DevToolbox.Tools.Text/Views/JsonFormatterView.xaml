<UserControl x:Class="DevToolbox.Tools.Text.Views.JsonFormatterView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="800"
             Background="#F7F5F1">
    <Grid>
        <!-- 工具栏 -->
        <Border Background="White"
                BorderBrush="#E7E3DA"
                BorderThickness="0,0,0,1"
                Height="50"
                VerticalAlignment="Top">
            <Grid Margin="15,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <TextBlock Text="JSON 格式化"
                              FontSize="16"
                              FontWeight="SemiBold"
                              Foreground="#1E2227"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button Content="格式化 (F4)"
                           Click="FormatButton_Click"
                           Height="32"
                           Padding="15,0"
                           Background="#3C5A78"
                           Foreground="White"
                           BorderThickness="0"
                           Cursor="Hand"
                           Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                   CornerRadius="4"
                                                   Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2E4760"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="压缩 (F5)"
                           Click="MinifyButton_Click"
                           Height="32"
                           Padding="15,0"
                           Background="White"
                           Foreground="#1E2227"
                           BorderBrush="#E7E3DA"
                           BorderThickness="1"
                           Cursor="Hand"
                           Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                   BorderBrush="{TemplateBinding BorderBrush}"
                                                   BorderThickness="{TemplateBinding BorderThickness}"
                                                   CornerRadius="4"
                                                   Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F7F5F1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="复制 (Ctrl+Shift+C)"
                           Click="CopyButton_Click"
                           Height="32"
                           Padding="15,0"
                           Background="White"
                           Foreground="#1E2227"
                           BorderBrush="#E7E3DA"
                           BorderThickness="1"
                           Cursor="Hand"
                           Margin="0,0,8,0">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                   BorderBrush="{TemplateBinding BorderBrush}"
                                                   BorderThickness="{TemplateBinding BorderThickness}"
                                                   CornerRadius="4"
                                                   Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F7F5F1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button Content="清空"
                           Click="ClearButton_Click"
                           Height="32"
                           Padding="15,0"
                           Background="White"
                           Foreground="#1E2227"
                           BorderBrush="#E7E3DA"
                           BorderThickness="1"
                           Cursor="Hand">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                   BorderBrush="{TemplateBinding BorderBrush}"
                                                   BorderThickness="{TemplateBinding BorderThickness}"
                                                   CornerRadius="4"
                                                   Padding="{TemplateBinding Padding}">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#F7F5F1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 搜索框（默认隐藏）-->
        <Border x:Name="SearchPanel"
                Background="#FFF9E6"
                BorderBrush="#E7E3DA"
                BorderThickness="0,0,0,1"
                Height="40"
                VerticalAlignment="Top"
                Margin="0,50,0,0"
                Visibility="Collapsed">
            <Grid Margin="15,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="查找："
                              FontSize="13"
                              Foreground="#1E2227"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"/>
                    <TextBox x:Name="SearchTextBox"
                            Width="250"
                            Height="26"
                            Padding="8,4"
                            FontSize="13"
                            BorderBrush="#E7E3DA"
                            BorderThickness="1"
                            KeyDown="SearchTextBox_KeyDown"
                            TextChanged="SearchTextBox_TextChanged"/>
                    <Button Content="下一个"
                           Click="FindNext_Click"
                           Height="26"
                           Padding="12,0"
                           Background="White"
                           Foreground="#1E2227"
                           BorderBrush="#E7E3DA"
                           BorderThickness="1"
                           Cursor="Hand"
                           Margin="8,0,4,0"/>
                    <Button Content="上一个"
                           Click="FindPrevious_Click"
                           Height="26"
                           Padding="12,0"
                           Background="White"
                           Foreground="#1E2227"
                           BorderBrush="#E7E3DA"
                           BorderThickness="1"
                           Cursor="Hand"
                           Margin="0,0,8,0"/>
                    <CheckBox x:Name="HighlightAllCheckBox"
                             Content="高亮全部"
                             VerticalAlignment="Center"
                             Checked="HighlightAll_Changed"
                             Unchecked="HighlightAll_Changed"
                             Margin="0,0,8,0"/>
                    <TextBlock x:Name="SearchResultText"
                              Text=""
                              FontSize="12"
                              Foreground="#6B7077"
                              VerticalAlignment="Center"
                              Margin="0,0,8,0"/>
                </StackPanel>

                <Button Content="✕"
                       Click="CloseSearch_Click"
                       Width="26"
                       Height="26"
                       Background="Transparent"
                       Foreground="#6B7077"
                       BorderThickness="0"
                       Cursor="Hand"
                       HorizontalAlignment="Right"
                       FontSize="16"/>
            </Grid>
        </Border>

        <!-- 编辑区域 -->
        <Border x:Name="EditorBorder" Margin="0,50,0,30" Background="White">
            <avalonedit:TextEditor x:Name="JsonEditor"
                                  FontFamily="Consolas"
                                  FontSize="17"
                                  ShowLineNumbers="True"
                                  WordWrap="False"
                                  HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto"
                                  Loaded="JsonEditor_Loaded"
                                  PreviewKeyDown="JsonEditor_PreviewKeyDown"
                                  PreviewMouseWheel="JsonEditor_PreviewMouseWheel"
                                  TextChanged="JsonEditor_TextChanged"/>
        </Border>

        <!-- 状态栏 -->
        <Border Background="White"
                BorderBrush="#E7E3DA"
                BorderThickness="0,1,0,0"
                Height="30"
                VerticalAlignment="Bottom">
            <Grid Margin="15,0">
                <TextBlock x:Name="StatusText"
                          Text="就绪"
                          FontSize="12"
                          Foreground="#6B7077"
                          VerticalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="LineColumnText"
                              Text="第 1 行，第 1 列"
                              FontSize="12"
                              Foreground="#6B7077"
                              Margin="0,0,15,0"/>
                    <TextBlock x:Name="CharCountText"
                              Text="0 字符"
                              FontSize="12"
                              Foreground="#6B7077"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
