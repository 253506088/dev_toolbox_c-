<Window x:Class="DevToolbox.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DevToolbox.App"
        mc:Ignorable="d"
        Title="DevToolbox - 开发者工具箱"
        Height="700"
        Width="1200"
        MinHeight="600"
        MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F7F5F1">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧导航栏 -->
        <Border Grid.Column="0"
                Background="White"
                BorderBrush="#E7E3DA"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="80"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Logo 和标题 -->
                <StackPanel Grid.Row="0"
                           VerticalAlignment="Center"
                           Margin="20,0">
                    <TextBlock Text="DevToolbox"
                              FontSize="24"
                              FontWeight="SemiBold"
                              Foreground="#1E2227"/>
                    <TextBlock Text="开发者工具箱"
                              FontSize="12"
                              Foreground="#6B7077"
                              Margin="0,4,0,0"/>
                </StackPanel>

                <!-- 工具列表 -->
                <ScrollViewer Grid.Row="1"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl x:Name="ToolsItemsControl" Margin="10">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Content="{Binding Name}"
                                       Height="40"
                                       Margin="0,0,0,4"
                                       HorizontalContentAlignment="Left"
                                       Padding="15,0"
                                       Background="Transparent"
                                       BorderThickness="0"
                                       Foreground="#1E2227"
                                       FontSize="14"
                                       Cursor="Hand"
                                       Click="ToolButton_Click"
                                       Tag="{Binding}">
                                    <Button.Style>
                                        <Style TargetType="Button">
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                               CornerRadius="6"
                                                               Padding="{TemplateBinding Padding}">
                                                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                            VerticalAlignment="Center"/>
                                                        </Border>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                            <Style.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#F7F5F1"/>
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 右侧工具承载区 -->
        <Grid Grid.Column="1">
            <ContentControl x:Name="ToolContentControl"
                          Margin="30">
                <TextBlock Text="请从左侧选择一个工具"
                          FontSize="16"
                          Foreground="#6B7077"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"/>
            </ContentControl>
        </Grid>
    </Grid>
</Window>
